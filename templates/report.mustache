{{!
    @template local_cohortmembership/report

    Example context (json):
    {
        "counters": {
            "total": 1,
            "valid": 1,
            "processed": 1,
            "skipped": 0,
            "errors": 0,
            "warnings": 0
        },
        "rows": [
            {
                "username": "hans.muster",
                "cohortid": "3",
                "cohortidnumber": "kurs-inf-2026",
                "operation": "add",
                "status_readable": "Added",
                "cohortsync_warning": false
            }
        ]
    }
}}
<div class="local-cohortmembership-report">
  <h4>{{#str}} summary, local_cohortmembership {{/str}}</h4>
  <ul>
    <li>{{#str}} rows_total, local_cohortmembership {{/str}}: {{counters.total}}</li>
    <li>{{#str}} rows_valid, local_cohortmembership {{/str}}: {{counters.valid}}</li>
    <li>{{#str}} rows_processed, local_cohortmembership {{/str}}: {{counters.processed}}</li>
    <li>{{#str}} rows_skipped, local_cohortmembership {{/str}}: {{counters.skipped}}</li>
    <li>{{#str}} rows_errors, local_cohortmembership {{/str}}: {{counters.errors}}</li>
    <li>{{#str}} rows_warnings, local_cohortmembership {{/str}}: {{counters.warnings}}</li>
  </ul>

  <table class="generaltable">
    <thead>
      <tr>
        <th>username</th>
        <th>cohortid</th>
        <th>cohortidnumber</th>
        <th>operation</th>
        <th>{{#str}} status, moodle {{/str}}</th>
        <th>{{#str}} cohortsynccolumn, local_cohortmembership {{/str}}</th>
      </tr>
    </thead>
    <tbody>
      {{#rows}}
      <tr>
        <td>{{username}}</td>
        <td>{{cohortid}}</td>
        <td>{{cohortidnumber}}</td>
        <td>{{operation}}</td>
        <td>{{status_readable}}</td>
        <td>
          {{#cohortsync_warning}}{{#str}} yes, moodle {{/str}}{{/cohortsync_warning}}
          {{^cohortsync_warning}}{{#str}} no, moodle {{/str}}{{/cohortsync_warning}}
        </td>
      </tr>
      {{/rows}}
    </tbody>
  </table>
</div>